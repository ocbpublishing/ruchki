import cv2
import pyautogui
import math
import mediapipe.python.solutions.hands as mp_hands
import mediapipe.python.solutions.drawing_utils as mp_draw

pyautogui.FAILSAFE = False

cap = cv2.VideoCapture(0)
screen_w, screen_h = pyautogui.size()

hands = mp_hands.Hands(max_num_hands=1, min_detection_confidence=0.7)

while cap.isOpened():
    success, img = cap.read()
    if not success:
        break

    img = cv2.flip(img, 1)
    img_h, img_w, _ = img.shape
    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    
    results = hands.process(img_rgb)

    if results.multi_hand_landmarks:
        for hand_lms in results.multi_hand_landmarks:
            mp_draw.draw_landmarks(img, hand_lms, mp_hands.HAND_CONNECTIONS)
            
            x8 = int(hand_lms.landmark[8].x * img_w)
            y8 = int(hand_lms.landmark[8].y * img_h)
            
            x4 = int(hand_lms.landmark[4].x * img_w)
            y4 = int(hand_lms.landmark[4].y * img_h)
            
            screen_x = int(screen_w / img_w * x8)
            screen_y = int(screen_h / img_h * y8)
            
            pyautogui.moveTo(screen_x, screen_y)
            
            length = math.hypot(x8 - x4, y8 - y4)
            
            if length < 30:
                pyautogui.click()
                cv2.circle(img, (x8, y8), 15, (0, 255, 0), cv2.FILLED)

    cv2.imshow("Hand Mouse Control", img)
    
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()
